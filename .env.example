# Copy to .env and edit. .env is consumed by docker-compose.

# ---- Public URL of the deployed app (used for CORS + email links).
APP_URL=http://localhost:8080
WEB_PORT=8080

# ---- JWT (REQUIRED). Generate a 256-bit random string, e.g.:
#   openssl rand -base64 48
JWT_SECRET=
JWT_ISSUER=CRM
JWT_AUDIENCE=CRM
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ---- Database. Default: SQLite at /data/crm.db inside the api container.
# To use SQL Server:
#   DATABASE_PROVIDER=SqlServer
#   CONNECTION_STRING=Server=sqlserver;Database=crm;User Id=sa;Password=<strong>;TrustServerCertificate=True;
DATABASE_PROVIDER=Sqlite
CONNECTION_STRING=Data Source=/data/crm.db

# ---- Email (Brevo / Gmail / SES). Required for password reset + email confirmation.
EMAIL_PROVIDER=Smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@your-domain.com
EMAIL_FROM_NAME=Rock Communication CRM
SUPPORT_EMAIL=support@your-domain.com

# ---- Optional vendors. Leave blank to use stubs.
SMS_PROVIDER=Stub
SMS_API_KEY=
SMS_FROM=

AI_PROVIDER=Stub
AI_API_KEY=
AI_MODEL=gpt-4o-mini
