{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=/data/crm.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Seed": {
    "DummyData": false
  },
  "BackgroundJobs": {
    "Provider": "InProcess"
  }
}
